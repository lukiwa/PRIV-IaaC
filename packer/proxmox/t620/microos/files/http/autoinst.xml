        <service>soft-reboot-cleanup</service>
        <service>qemu-guest-agent</service>
        <service>sshd</service>
        <service>systemd-pstore</service>
        <service>systemd-remount-fs</service>
        <service>wtmpdb-update-boot</service>
      </enable>
      <on_demand t="list">
        <listentry>wtmpdbd</listentry>
      </on_demand>
    </services>
  </services-manager>
