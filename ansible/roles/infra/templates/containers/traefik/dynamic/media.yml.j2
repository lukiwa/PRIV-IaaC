http:
  routers:
    bazarr:
      rule: "Host(`bazarr.{{ infra_traefik_domain }}`)"
      service: bazarr
      entryPoints:
        - web
    prowlarr:
      rule: "Host(`prowlarr.{{ infra_traefik_domain }}`)"
      service: prowlarr
      entryPoints:
        - web
    deluge:
      rule: "Host(`deluge.{{ infra_traefik_domain }}`)"
      service: deluge
      entryPoints:
        - web
    radarr:
      rule: "Host(`radarr.{{ infra_traefik_domain }}`)"
      service: radarr
      entryPoints:
        - web
    sonarr:
      rule: "Host(`sonarr.{{ infra_traefik_domain }}`)"
      service: sonarr
      entryPoints:
        - web

  services:
    bazarr:
      loadBalancer:
        servers:
          - url: "http://{{ infra_traefik_media_host }}:6767"
    prowlarr:
      loadBalancer:
        servers:
          - url: "http://{{ infra_traefik_media_host }}:9696"
    deluge:
      loadBalancer:
        servers:
          - url: "http://{{ infra_traefik_media_host }}:8112"
    radarr:
      loadBalancer:
        servers:
          - url: "http://{{ infra_traefik_media_host }}:7878"
    sonarr:
      loadBalancer:
        servers:
          - url: "http://{{ infra_traefik_media_host }}:8989"
