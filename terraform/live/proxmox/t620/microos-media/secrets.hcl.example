# op inject -i secrets.hcl.example -o secrets.hcl

locals {
  macaddr    = "{{op://Private/Proxmox-T620-Media/macaddr}}"
  public_key = "{{op://Private/Proxmox-T620-Media/public key}}"
  password   = "{{op://Private/Proxmox-T620-Media/password}}"
  # Full path, e.g. /dev/disk/by-id/ata-... or /dev/disk/by-uuid/... Leave empty to skip passthrough.
  disk_path  = "{{op://Private/Proxmox-T620-Media/disk_path}}"
}
