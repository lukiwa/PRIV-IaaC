# Copy this snippet to variables_secrets.tfvars and fill-in values or use:
# op inject -i variables_secrets.tfvars.example -o variables_secrets.tfvars
# to populate this file from 1password vault.
# NOTE: proxmox_api_url = "<IP/DN>:8006/api2/json"

proxmox_api_url          = "{{op://Private/Proxmox-Terraform/api_url}}"
proxmox_api_token_id     = "{{op://Private/Proxmox-Terraform/token_id}}"
proxmox_api_token_secret = "{{op://Private/Proxmox-Terraform/token_secret}}"
